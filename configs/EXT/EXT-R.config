 no shutdown
 encapsulation dot1Q 903
 ip vrf forwarding TN-C
 ip address 172.31.0.18 255.255.255.248
 ip nat inside
 ip virtual-reassembly in
!
interface Ethernet0/1
 no shutdown
 ip address 121.160.1.2 255.255.255.0
 ip nat outside
 ip virtual-reassembly in
!
interface Ethernet0/2
 no shutdown
 no ip address
!
interface Ethernet0/3
 no shutdown
 ip vrf forwarding MGMT
 ip address 10.1.2.28 255.255.255.0
!
router bgp 65100
 bgp log-neighbor-changes
 !
 address-family ipv4 vrf TN-A
  neighbor 172.31.0.1 remote-as 65000
  neighbor 172.31.0.1 activate
  default-information originate
 exit-address-family
 !
 address-family ipv4 vrf TN-B
  neighbor 172.31.0.9 remote-as 65000
  neighbor 172.31.0.9 activate
  default-information originate
 exit-address-family
 !
 address-family ipv4 vrf TN-C
  neighbor 172.31.0.17 remote-as 65000
  neighbor 172.31.0.17 activate
  default-information originate
 exit-address-family
!
ip forward-protocol nd
!
!
no ip http server
no ip http secure-server
!
snmp-server community CYNK-TECH RO
snmp-server location NAVIS
snmp-server contact admin
ntp server vrf MGMT 192.168.0.203
ip nat inside source static 10.10.10.15 121.160.1.10 vrf TN-A
ip nat inside source static 10.10.20.15 121.160.1.20 vrf TN-A
ip route 8.8.8.8 255.255.255.255 121.160.1.1
ip route 10.10.0.0 255.255.0.0 Ethernet0/0.901
ip route vrf TN-A 0.0.0.0 0.0.0.0 121.160.1.1 global
ip route vrf TN-B 0.0.0.0 0.0.0.0 121.160.1.1 global
ip route vrf TN-C 0.0.0.0 0.0.0.0 121.160.1.1 global
ip route vrf MGMT 0.0.0.0 0.0.0.0 10.1.2.254
