!
!
!
!
!
!
!
!
!
!
!
interface Loopback0
 no shutdown
 ip address 192.168.0.51 255.255.255.255
!
interface Ethernet0/0
 no shutdown
 no ip address
!
interface Ethernet0/0.901
 no shutdown
 encapsulation dot1Q 901
 ip vrf forwarding TN-A
 ip address 172.31.0.2 255.255.255.248
 ip nat inside
 ip virtual-reassembly in
!
interface Ethernet0/0.902
 no shutdown
 encapsulation dot1Q 902
 ip vrf forwarding TN-B
 ip address 172.31.0.10 255.255.255.248
 ip nat inside
 ip virtual-reassembly in
